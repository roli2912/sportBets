# Copy to .env and fill in. Never commit .env (see CLAUDE.md §14).
# Provider keys follow the {PROVIDER}_API_KEY convention.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

THERUNDOWN_API_KEY=
ODDSPAPI_API_KEY=
API_FOOTBALL_API_KEY=
FOOTBALL_DATA_API_KEY=
PANDASCORE_API_KEY=
ANTHROPIC_API_KEY=

# Telegram publishing (§13 Task 4). Unset = publisher stays off.
TELEGRAM_API_KEY=
TELEGRAM_CHAT_ID=
# TELEGRAM_BACKFILL_HOURS=24

# Nightly append-only proof export (§6). Point at a clone of the PUBLIC
# proof repo; set PROOF_EXPORT_GIT=1 to auto commit+push.
PROOF_EXPORT_DIR=
# PROOF_EXPORT_GIT=1

# Daily Best Bets feed build hour (UTC, §13 Task 2)
# FEED_BUILD_HOUR_UTC=6

# Integration tests only run when this is set (CI sets it against a service container)
TEST_DATABASE_URL=
